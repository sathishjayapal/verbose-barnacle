# Copy to .env (gitignored) and adjust as needed.
# Read by docker-compose.yml, by consolidated-postgres orchestration
# (scripts/vm/vm-db-up.sh, acg-start.sh, acg-aws-start.sh), and by the app
# itself via `spring.config.import: optional:file:.env[.properties]`
# (see my-github-cleaner-base/src/main/resources/application.yml).
#
# IMPORTANT: CONFIG_SERVER_URL, SPRING_CLOUD_CONFIG_USERNAME, and
# SPRING_CLOUD_CONFIG_PASSWORD must be set as REAL shell/IDE environment
# variables, not just present in this file. Spring Boot resolves
# `configserver:${CONFIG_SERVER_URL}` (the second entry in spring.config.import)
# BEFORE properties loaded by the first entry (this .env file) become
# available, so a value that only lives in .env never resolves in time —
# you'll see "Invalid URL: ${CONFIG_SERVER_URL}" even though the file has it.
# Export them in your shell profile or your IDE run configuration's
# "Environment variables" field.
#
# my-github-cleaner-base/.env is a symlink to this file — don't recreate it
# as a separate copy, or the two will drift again (that's what happened before).

# ── Config server (see IMPORTANT note above) ──
CONFIG_SERVER_URL=http://192.168.4.39:8888
SPRING_CLOUD_CONFIG_USERNAME=cfg_local
SPRING_CLOUD_CONFIG_PASSWORD=changeme

# ── Database (name/user/url must all agree — see consolidated-postgres/projects.txt) ──
GITHUB_CLEANER_DB_NAME=my-github-cleaner
GITHUB_CLEANER_DB_USER=postgres
GITHUB_CLEANER_DB_PASSWORD=changeme
GITHUB_CLEANER_DB_URL=jdbc:postgresql://192.168.4.39:5439/my-github-cleaner

# ── RabbitMQ (shared broker on the VM) ──
RABBITMQ_HOST=192.168.4.39
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=changeme
RABBITMQ_PASSWORD=changeme

# ── EventTracker integration — EventTrackerService.java reads these as raw,
#    exact-case env var names via environment.getProperty(), not through YAML ──
EVENTSTRACKER_URL=http://192.168.4.39:9081
eventstracker_username=changeme
eventstracker_password=changeme

# ── sathishlogger — GitHubDataRunner reads the URL unconditionally even when
#    disabled, so it must have a value regardless of SATHISHLOGGER_ENABLED ──
SATHISHLOGGER_URL=http://192.168.4.39:8090
SATHISHLOGGER_APP_NAME=my-github-cleaner

# ── GitHub API ──
GITHUB_TOKEN=changeme
githubusername=changeme
githuborgkey=changeme

# ── Basic-auth users for the app's own security realm (lazy-loaded, not
#    required at boot, but needed to actually log in) ──
app.security.admin.username=admin
app.security.admin.password=changeme
app.security.viewer.username=viewer
app.security.viewer.password=changeme
